{
  "name": "just-youtrack-helpdesk-ticket-2-issue-sync",
  "description": "Auto-create and sync linked dev issues from helpdesk tickets",
  "module": "index.ts",
  "type": "module",
  "private": true,
  "version": "0.1.0",
  "scripts": {
    "prebuild": "rm -rf dist",
    "build": "bun run build.ts",
    "upload": "bun run build.ts && youtrack-workflow upload ./dist --host $YT_HOST --token $YT_TOKEN",
    "prezip": "rm -rf helpdesk-sync.zip",
    "zip": "bun run build.ts --zip"
  },
  "devDependencies": {
    "@jetbrains/youtrack-scripting-api": "latest",
    "@types/archiver": "^7.0.0",
    "@types/bun": "latest",
    "archiver": "^7.0.1",
    "youtrack-workflow-api-types": "^0.2.4"
  },
  "peerDependencies": {
    "typescript": "^5"
  }
}
